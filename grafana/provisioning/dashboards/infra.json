      },
      "datasource": {
        "type": "prometheus",
        "uid": "infra-prometheus"
      },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "infra-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list"
        }
      }
    },
