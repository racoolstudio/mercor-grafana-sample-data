{
  "uid": "infra-main",
  "title": "Infrastructure Monitoring",
  "tags": ["infrastructure", "prometheus"],
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage %",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "infra-prometheus" },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "infra-prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 2,
      "title": "Memory Usage %",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "infra-prometheus" },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "infra-prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 3,
      "title": "Disk Usage %",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "infra-prometheus" },
      "targets": [
        {
          "expr": "max(100 - ((node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100))",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "infra-prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 4,
      "title": "Network RX",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "infra-prometheus" },
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_bytes_total[5m]))",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "infra-prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "max": 1000000000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100000000 },
              { "color": "red", "value": 500000000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 5,
      "title": "CPU Usage Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "infra-prometheus" },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "infra-prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "options": { "legend": { "displayMode": "list" } }
    },
    {
      "id": 6,
      "title": "Memory Available",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "infra-prometheus" },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "infra-prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "legend": { "displayMode": "list" } }
    },
    {
      "id": 7,
      "title": "Network RX (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "infra-prometheus" },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total[5m])",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "infra-prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "options": { "legend": { "displayMode": "list" } }
    },
    {
      "id": 8,
      "title": "Network TX (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "infra-prometheus" },
      "targets": [
        {
          "expr": "rate(node_network_transmit_bytes_total[5m])",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "infra-prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "options": { "legend": { "displayMode": "list" } }
    },
    {
      "id": 9,
      "title": "Disk Read Throughput",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "infra-prometheus" },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total[5m])",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "infra-prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "options": { "legend": { "displayMode": "list" } }
    },
    {
      "id": 10,
      "title": "Disk Write Throughput",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "infra-prometheus" },
      "targets": [
        {
          "expr": "rate(node_disk_written_bytes_total[5m])",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "infra-prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "options": { "legend": { "displayMode": "list" } }
    },
    {
      "id": 11,
      "title": "Open File Descriptors",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 30, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "infra-prometheus" },
      "targets": [
        {
          "expr": "node_filefd_allocated",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "infra-prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } },
      "options": { "legend": { "displayMode": "list" } }
    },
    {
      "id": 12,
      "title": "System Load (1m / 5m / 15m)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 30, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "infra-prometheus" },
      "targets": [
        {
          "expr": "node_load1",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "infra-prometheus" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } },
      "options": { "legend": { "displayMode": "list" } }
    }
  ],
  "schemaVersion": 36,
  "version": 2,
  "id": null
}
