{
  "uid": "iot-main",
  "title": "IoT & Server Monitoring",
  "tags": [
    "iot",
    "influxdb"
  ],
  "timezone": "browser",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {},
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "title": "Avg CPU (1h)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "influxdb",
        "uid": "iot-influxdb"
      },
      "targets": [
        {
          "query": "from(bucket: \"iot\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"server_metrics\" and r._field == \"cpu_usage\")\n  |> group(columns: [\"_field\"])\n  |> mean()",
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "iot-influxdb"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "mean"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
