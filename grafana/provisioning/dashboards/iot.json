{
  "uid": "iot-main",
  "title": "IoT & Server Monitoring",
  "tags": ["iot", "influxdb"],
  "timezone": "browser",
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "title": "Avg CPU (1h)",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "datasource": { "type": "influxdb", "uid": "iot-influxdb" },
      "targets": [
        {
          "query": "from(bucket:\"iot\") |> range(start:-1h) |> filter(fn:(r)=>r._measurement==\"server_metrics\" and r._field==\"cpu_usage\") |> group(columns:[\"_field\"]) |> mean()",
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "iot-influxdb" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 2,
      "title": "Avg Memory (1h)",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 },
      "datasource": { "type": "influxdb", "uid": "iot-influxdb" },
      "targets": [
        {
          "query": "from(bucket:\"iot\") |> range(start:-1h) |> filter(fn:(r)=>r._measurement==\"server_metrics\" and r._field==\"memory_usage\") |> group(columns:[\"_field\"]) |> mean()",
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "iot-influxdb" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 3,
      "title": "Avg Temperature (1h)",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 6 },
      "datasource": { "type": "influxdb", "uid": "iot-influxdb" },
      "targets": [
        {
          "query": "from(bucket:\"iot\") |> range(start:-1h) |> filter(fn:(r)=>r._measurement==\"iot_sensors\" and r._field==\"temperature\") |> group(columns:[\"_field\"]) |> mean()",
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "iot-influxdb" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": -10,
          "max": 50,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "red", "value": 35 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 4,
      "title": "Avg API Latency (1h)",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 6 },
      "datasource": { "type": "influxdb", "uid": "iot-influxdb" },
      "targets": [
        {
          "query": "from(bucket:\"iot\") |> range(start:-1h) |> filter(fn:(r)=>r._measurement==\"app_metrics\" and r._field==\"latency_ms\") |> group(columns:[\"_field\"]) |> mean()",
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "iot-influxdb" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 1000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 5,
      "title": "CPU Usage by Server (7d)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "iot-influxdb" },
      "targets": [
        {
          "query": "from(bucket: \"iot\")\n  |> range(start: -7d)\n  |> filter(fn: (r) => r._measurement == \"server_metrics\" and r._field == \"cpu_usage\")\n  |> aggregateWindow(every: 1h, fn: mean, createEmpty: false)",
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "iot-influxdb" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "options": { "legend": { "displayMode": "list" } }
    },
    {
