      "type": "barchart",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "mysql",
        "uid": "PFAC19024CD8D7C0E"
      },
      "targets": [
        {
          "rawSql": "SELECT a.company_name, ROUND(SUM(s.mrr),2) as MRR FROM subscriptions s JOIN accounts a ON s.account_id=a.account_id WHERE s.status='active' GROUP BY s.account_id ORDER BY MRR DESC LIMIT 10",
          "format": "table",
          "refId": "A",
