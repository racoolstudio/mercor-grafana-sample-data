    {
      "id": 5,
      "title": "MRR Over Time (Monthly)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "mysql",
        "uid": "PFAC19024CD8D7C0E"
      },
      "targets": [
        {
          "rawSql": "SELECT DATE_FORMAT(i.issued_at, '%Y-%m-01') as time, ROUND(SUM(i.amount),2) as MRR FROM invoices i WHERE i.status='paid' GROUP BY DATE_FORMAT(i.issued_at, '%Y-%m-01') ORDER BY time",
          "format": "time_series",
          "refId": "A",
          "datasource": {
            "type": "mysql",
            "uid": "PFAC19024CD8D7C0E"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list"
        }
      }
    },
    {
      "id": 6,
      "title": "New Accounts per Month",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "mysql",
        "uid": "PFAC19024CD8D7C0E"
      },
      "targets": [
        {
          "rawSql": "SELECT DATE_FORMAT(created_at,'%Y-%m-01') as time, COUNT(*) as NewAccounts FROM accounts GROUP BY DATE_FORMAT(created_at,'%Y-%m-01') ORDER BY time",
