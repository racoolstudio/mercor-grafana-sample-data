      },
      "targets": [
        {
          "rawSql": "SELECT SUM(plan='starter') as Starter, SUM(plan='growth') as Growth, SUM(plan='business') as Business, SUM(plan='enterprise') as Enterprise FROM subscriptions WHERE status='active'",
