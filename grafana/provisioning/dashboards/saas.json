        "h": 4
      },
      "datasource": {
        "type": "mysql",
        "uid": "PFAC19024CD8D7C0E"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(100.0*SUM(status='churned')/COUNT(*),1) as ChurnPct FROM subscriptions",
          "format": "table",
          "refId": "A",
          "datasource": {
            "type": "mysql",
            "uid": "PFAC19024CD8D7C0E"
          }
        }
