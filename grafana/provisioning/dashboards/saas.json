      },
      "targets": [
        {
          "rawSql": "SELECT DATE_FORMAT(occurred_at,'%Y-%m-%d') as time, COUNT(DISTINCT user_id) as DAU FROM events WHERE occurred_at >= NOW() - INTERVAL 90 DAY GROUP BY DATE_FORMAT(occurred_at,'%Y-%m-%d') ORDER BY time",
