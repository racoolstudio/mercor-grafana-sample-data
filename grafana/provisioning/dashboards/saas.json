      },
      "targets": [
        {
          "rawSql": "SELECT SUM(industry='SaaS') as SaaS, SUM(industry='E-commerce') as Ecommerce, SUM(industry='Healthcare') as Healthcare, SUM(industry='Finance') as Finance, SUM(industry='Education') as Education, SUM(industry='Marketing') as Marketing, SUM(industry='Real Estate') as RealEstate, SUM(industry='Logistics') as Logistics FROM accounts",
