    {
      "id": 1,
      "title": "Total MRR",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "mysql",
        "uid": "PFAC19024CD8D7C0E"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(SUM(mrr),2) as MRR FROM subscriptions WHERE status='active'",
          "format": "table",
          "refId": "A",
          "datasource": {
            "type": "mysql",
            "uid": "PFAC19024CD8D7C0E"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
