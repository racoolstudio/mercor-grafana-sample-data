      },
      "targets": [
        {
          "rawQueryText": "SELECT SUM(CASE WHEN payment_method='visa' THEN 1 ELSE 0 END) as Visa, SUM(CASE WHEN payment_method='mastercard' THEN 1 ELSE 0 END) as Mastercard, SUM(CASE WHEN payment_method='paypal' THEN 1 ELSE 0 END) as PayPal, SUM(CASE WHEN payment_method='amex' THEN 1 ELSE 0 END) as Amex, SUM(CASE WHEN payment_method='apple_pay' THEN 1 ELSE 0 END) as Apple_Pay, SUM(CASE WHEN payment_method='google_pay' THEN 1 ELSE 0 END) as Google_Pay, SUM(CASE WHEN payment_method='discover' THEN 1 ELSE 0 END) as Discover FROM orders",
          "format": "table",
          "datasource": {
            "type": "frser-sqlite-datasource",
            "uid": "P605BCAF4254240A5"
          }
        }
      ],
      "options": {
        "pieType": "pie",
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
