      },
      "targets": [
        {
          "rawQueryText": "SELECT p.name, ROUND(SUM(oi.quantity*oi.unit_price),2) as Revenue FROM order_items oi JOIN products p ON oi.product_id=p.product_id JOIN orders o ON oi.order_id=o.order_id WHERE o.status='completed' GROUP BY p.product_id ORDER BY Revenue DESC LIMIT 10",
          "format": "table",
          "datasource": {
            "type": "frser-sqlite-datasource",
            "uid": "P605BCAF4254240A5"
