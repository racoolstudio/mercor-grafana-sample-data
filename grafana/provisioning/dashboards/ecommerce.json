    {
      "id": 7,
      "title": "Orders by Status",
      "type": "piechart",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "P605BCAF4254240A5"
      },
      "targets": [
        {
          "rawQueryText": "SELECT SUM(CASE WHEN status='completed' THEN 1 ELSE 0 END) as Completed, SUM(CASE WHEN status='shipped' THEN 1 ELSE 0 END) as Shipped, SUM(CASE WHEN status='processing' THEN 1 ELSE 0 END) as Processing, SUM(CASE WHEN status='refunded' THEN 1 ELSE 0 END) as Refunded, SUM(CASE WHEN status='cancelled' THEN 1 ELSE 0 END) as Cancelled FROM orders",
          "format": "table",
          "datasource": {
            "type": "frser-sqlite-datasource",
            "uid": "P605BCAF4254240A5"
          }
        }
      ],
      "options": {
        "pieType": "pie",
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      }
    },
    {
      "id": 8,
      "title": "Revenue by Category",
      "type": "piechart",
      "gridPos": {
        "x": 8,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "P605BCAF4254240A5"
      },
      "targets": [
        {
          "rawQueryText": "SELECT ROUND(SUM(CASE WHEN p.category='Electronics' THEN oi.quantity*oi.unit_price ELSE 0 END),0) as Electronics, ROUND(SUM(CASE WHEN p.category='Clothing' THEN oi.quantity*oi.unit_price ELSE 0 END),0) as Clothing, ROUND(SUM(CASE WHEN p.category='Home & Kitchen' THEN oi.quantity*oi.unit_price ELSE 0 END),0) as Home_Kitchen, ROUND(SUM(CASE WHEN p.category='Sports & Outdoors' THEN oi.quantity*oi.unit_price ELSE 0 END),0) as Sports_Outdoors, ROUND(SUM(CASE WHEN p.category='Books' THEN oi.quantity*oi.unit_price ELSE 0 END),0) as Books FROM order_items oi JOIN products p ON oi.product_id=p.product_id JOIN orders o ON oi.order_id=o.order_id WHERE o.status='completed'",
          "format": "table",
          "datasource": {
            "type": "frser-sqlite-datasource",
            "uid": "P605BCAF4254240A5"
          }
        }
      ],
      "options": {
        "pieType": "pie",
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      }
    },
    {
      "id": 9,
      "title": "Payment Method Breakdown",
      "type": "piechart",
      "gridPos": {
        "x": 16,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
