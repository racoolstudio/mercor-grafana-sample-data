      },
      "targets": [
        {
          "rawQueryText": "SELECT CAST(strftime('%s', strftime('%Y-%m-01', order_date)) AS INTEGER) as time, ROUND(SUM(total),2) as Revenue FROM orders WHERE status='completed' GROUP BY strftime('%Y-%m', order_date) ORDER BY time",
